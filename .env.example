# ── Database (PGVector in Docker) ───────────────────────────────
POSTGRES_USER=finserv
POSTGRES_PASSWORD=finserv_local_dev
POSTGRES_DB=compliance
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://finserv:finserv_local_dev@localhost:5432/compliance

# ── LLM (local via Ollama) ──────────────────────────────────────
# Local prototype model. Production swaps this to a 70B — model name is the
# ONLY thing that changes between local and production.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT_SECONDS=120
LLM_NUM_CTX=4096

# ── Embeddings & reranker (local, sentence-transformers) ────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
EMBEDDING_DIM=384

# ── Retrieval tuning ────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_N=4
HYBRID_RRF_K=60
RETRIEVAL_SCORE_THRESHOLD=0.3

# ── Chunking ────────────────────────────────────────────────────
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_RATIO=0.12

# ── Paths ───────────────────────────────────────────────────────
DATA_DIR=./data
EVAL_SET_PATH=./data/eval_set.json
EVAL_REPORT_PATH=./eval_report.md

# ── Eval (judge model = local Ollama, open-source constraint) ───
EVAL_JUDGE_MODEL=qwen2.5:3b
